{
  "manifest_version": 3,
  "name": "AI Form Filler",
  "version": "5.2",
  "description": "Auto-fill government and cyber cafe forms with AI in one click.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://formfiller.ai-workflows.cloud/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
